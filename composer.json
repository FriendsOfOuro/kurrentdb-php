{
    "name": "friendsofouro/kurrentdb",
    "description": "KurrentDB client for PHP - metapackage",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "eventsourcing",
        "eventstore",
        "KurrentDB"
    ],
    "authors": [
        {
            "name": "D. Bellettini",
            "email": "davide@bellettini.eu",
            "homepage": "http://bellettini.eu/"
        },
        {
            "name": "Nicolò Pignatelli",
            "email": "pignatelli.nicolo@gmail.com",
            "homepage": "http://nicolopignatelli.me/"
        },
        {
            "name": "Contributors",
            "homepage": "https://github.com/friendsofouro/geteventstore-php/graphs/contributors"
        }
    ],
    "require": {
        "php": "^8.3",
        "friendsofouro/kurrentdb-core": ">=0.13.0",
        "guzzlehttp/guzzle": "^7.10",
        "kevinrob/guzzle-cache-middleware": "^0.7.1",
        "symfony/cache": "^7.3"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "^2.48",
        "friendsofphp/php-cs-fixer": "^2.2",
        "phpunit/phpunit": "^12.3"
    },
    "replace": {
        "friendsofouro/geteventstore": "self.version"
    },
    "autoload": {
        "psr-0": {
            "EventStore": "src/"
        }
    },
    "autoload-dev": {
        "psr-0": {
            "EventStore": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true
        },
        "bin-dir": "bin",
        "sort-packages": true
    }
}
